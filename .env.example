# Copy this file to ".env" and replace placeholder values.
# Never commit ".env" because it may contain secrets.

# Server
PORT=19880

# Database (MySQL)
DB_NAME=giftverse
DB_ENDPOINT=localhost
USER=root
PASSWORD=change_me

# Video Processor (default: PixVerse CLI)
VIDEO_ENGINE=pixverse-cli
PIXVERSE_BIN=pixverse
VIDEO_MAX_CONCURRENCY=1

# Paths (optional)
VIDEO_JOBS_DIR=
VIDEO_PUBLIC_UPLOADS_ROOT=

# Video Processor (PixVerse Pipeline)
PIXVERSE_PIPELINE_ROOT=
PIPELINE_NODE_BIN=
